<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@700&family=Outfit:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <title>{{ .Title }}</title>
    <style>
      :root {
        --bg: {{ .BackgroundColor }};
        --accent: {{ .AccentColor }};
        --text: #e8e6e1;
        --text-dim: rgba(232, 230, 225, 0.5);
        --text-faint: rgba(232, 230, 225, 0.12);
        --line: rgba(232, 230, 225, 0.035);
        --panel-bg: rgba(232, 230, 225, 0.035);
        --panel-border: rgba(232, 230, 225, 0.08);
        --red: #ef5350;
        --amber: #ffa726;
      }

      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: "Outfit", sans-serif;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        position: relative;
      }

      /* ─── Topographic background ─── */

      .topo {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
      }

      .topo svg {
        width: 100%;
        height: 100%;
      }

      .topo .c {
        fill: none;
        stroke: var(--line);
        stroke-width: 1;
      }

      .topo .cs {
        fill: none;
        stroke: rgba(232, 230, 225, 0.055);
        stroke-width: 1.5;
      }

      .grid {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background-image: radial-gradient(
          circle,
          rgba(232, 230, 225, 0.015) 1px,
          transparent 1px
        );
        background-size: 48px 48px;
      }

      /* ─── Layout ─── */

      .wrap {
        position: relative;
        z-index: 1;
        width: 100%;
        max-width: 520px;
        animation: fadeUp 0.5s ease-out both;
      }

      @keyframes fadeUp {
        from {
          opacity: 0;
          transform: translateY(10px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      /* ─── Header ─── */

      .header {
        text-align: center;
        margin-bottom: 2rem;
      }

      .error-label {
        font-size: 0.65rem;
        font-weight: 500;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: {{ if eq .Type "error" }}var(--red){{ else }}var(--amber){{ end }};
        margin-bottom: 0.75rem;
      }

      .title {
        font-family: "Syne", sans-serif;
        font-weight: 700;
        font-size: clamp(1.3rem, 3vw, 1.7rem);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        line-height: 1.2;
      }

      .rule {
        width: 32px;
        height: 2px;
        background: {{ if eq .Type "error" }}var(--red){{ else }}var(--amber){{ end }};
        border: none;
        margin: 0.75rem auto;
      }

      .subtitle {
        font-weight: 300;
        font-size: 0.88rem;
        color: var(--text-dim);
        letter-spacing: 0.02em;
        line-height: 1.5;
      }

      /* ─── Message panel ─── */

      {{ if .Message }}
      .message {
        background: var(--panel-bg);
        border: 1px solid var(--panel-border);
        border-radius: 6px;
        padding: 1rem 1.2rem;
        margin-bottom: 1.5rem;
        font-size: 0.85rem;
        color: var(--text-dim);
        line-height: 1.6;
      }
      {{ end }}

      /* ─── Actions ─── */

      .actions {
        display: flex;
        gap: 0.75rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-bottom: 1.5rem;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.7rem 1.6rem;
        border: 1.5px solid;
        background: transparent;
        font-family: "Outfit", sans-serif;
        font-weight: 500;
        font-size: 0.8rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        text-decoration: none;
        border-radius: 3px;
        cursor: pointer;
        transition: all 0.25s ease;
        color: var(--text-dim);
        border-color: var(--panel-border);
      }

      .btn:hover {
        color: var(--text);
        border-color: var(--text-dim);
      }

      .btn:active {
        transform: scale(0.97);
      }

      .btn-accent {
        border-color: var(--accent);
        color: var(--accent);
      }

      .btn-accent:hover {
        background: var(--accent);
        color: var(--bg);
      }

      /* ─── Technical details ─── */

      {{ if .TechnicalDetails }}
      .details {
        border-top: 1px solid var(--panel-border);
        padding-top: 1.25rem;
      }

      .details-toggle {
        background: none;
        border: none;
        color: var(--text-faint);
        cursor: pointer;
        font-family: "Outfit", sans-serif;
        font-size: 0.7rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 0.4rem 0;
        transition: color 0.2s ease;
      }

      .details-toggle:hover {
        color: var(--text-dim);
      }

      .details-content {
        display: none;
        margin-top: 0.75rem;
        padding: 0.8rem 1rem;
        background: var(--panel-bg);
        border: 1px solid var(--panel-border);
        border-radius: 6px;
        font-size: 0.72rem;
        color: var(--text-faint);
        line-height: 1.7;
        white-space: pre-wrap;
        word-break: break-all;
        letter-spacing: 0.01em;
      }

      .details-content.visible {
        display: block;
      }
      {{ end }}

      /* ─── Responsive ─── */

      @media (max-width: 640px) {
        body {
          padding: 1.5rem 1rem;
        }

        .actions {
          flex-direction: column;
        }

        .btn {
          justify-content: center;
        }
      }
    </style>
  </head>
  <body>
    <div class="topo">
      <svg
        viewBox="0 0 1440 900"
        preserveAspectRatio="xMidYMid slice"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          class="c"
          d="M-20,860 C50,660 180,490 320,410 S520,350 580,430 530,610 420,810"
        />
        <path
          class="cs"
          d="M-80,900 C10,600 160,390 320,290 S560,210 660,350 590,570 460,840"
        />
        <path
          class="c"
          d="M1020,830 C1040,710 1100,600 1180,550 S1300,520 1340,590 1300,730 1200,830"
        />
        <path
          class="cs"
          d="M960,890 C1000,670 1060,520 1180,450 S1340,400 1400,510 1340,690 1220,880"
        />
        <path
          class="c"
          d="M-100,590 C200,550 450,610 700,570 S1050,530 1300,590 1540,560"
        />
        <path
          class="c"
          d="M-100,140 C200,120 500,160 800,130 S1200,110 1540,150"
        />
      </svg>
    </div>

    <div class="grid"></div>

    <div class="wrap">
      <div class="header">
        <div class="error-label">{{ if eq .Type "error" }}Error{{ else if eq .Type "warning" }}Warning{{ else }}Notice{{ end }}</div>
        <h1 class="title">{{ .Title }}</h1>
        <hr class="rule" />
        <p class="subtitle">{{ .Subtitle }}</p>
      </div>

      {{ if .Message }}
      <div class="message">{{ .Message }}</div>
      {{ end }}

      <div class="actions">
        {{ if .ShowRetry }}
        <button class="btn btn-accent" onclick="location.reload()">
          Try again
        </button>
        {{ end }}

        {{ if .ShowHome }}
        <a href="{{ .HomePath }}" class="btn">Home</a>
        {{ end }}

        {{ if .ShowLogout }}
        <form method="POST" action="{{ .LogoutPath }}">
          <button type="submit" class="btn">Sign out</button>
        </form>
        {{ end }}
      </div>

      {{ if .TechnicalDetails }}
      <div class="details">
        <button class="details-toggle" onclick="toggleDetails()">
          Technical details
        </button>
        <div id="details-content" class="details-content">{{ .TechnicalDetails }}</div>
      </div>
      {{ end }}
    </div>

    {{ if .TechnicalDetails }}
    <script>
      function toggleDetails() {
        var el = document.getElementById("details-content");
        el.classList.toggle("visible");
      }
    </script>
    {{ end }}
  </body>
</html>
