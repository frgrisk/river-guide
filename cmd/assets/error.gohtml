<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <title>{{ .Title }} - Error</title>
    <style>
        :root {
            --error-gradient: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
            --warning-gradient: linear-gradient(135deg, #feca57 0%, #ff9ff3 100%);
            --info-gradient: linear-gradient(135deg, #54a0ff 0%, #5f27cd 100%);
            --glass-bg: rgba(255, 255, 255, 0.1);
            --glass-border: rgba(255, 255, 255, 0.2);
            --text-primary: #ffffff;
            --text-secondary: rgba(255, 255, 255, 0.8);
            --shadow-lg: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            --shadow-xl: 0 35px 60px -12px rgba(0, 0, 0, 0.35);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: {{ if eq .Type "error" }}var(--error-gradient){{ else if eq .Type "warning" }}var(--warning-gradient){{ else }}var(--info-gradient){{ end }};
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow-x: hidden;
        }

        /* Animated background elements */
        .bg-animation {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
        }

        .bg-element {
            position: absolute;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.1);
            animation: float 8s ease-in-out infinite;
        }

        .bg-element:nth-child(1) {
            width: 300px;
            height: 300px;
            top: 5%;
            left: 5%;
            animation-delay: 0s;
        }

        .bg-element:nth-child(2) {
            width: 200px;
            height: 200px;
            top: 50%;
            right: 10%;
            animation-delay: 3s;
        }

        .bg-element:nth-child(3) {
            width: 150px;
            height: 150px;
            top: 20%;
            right: 30%;
            animation-delay: 6s;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0px) rotate(0deg); opacity: 0.5; }
            50% { transform: translateY(-30px) rotate(180deg); opacity: 0.8; }
        }

        /* Main container */
        .error-container {
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            padding: 3rem 2.5rem;
            min-width: 500px;
            max-width: 600px;
            box-shadow: var(--shadow-xl);
            position: relative;
            z-index: 1;
            text-align: center;
        }

        /* Error icon */
        .error-icon {
            width: 120px;
            height: 120px;
            margin: 0 auto 2rem;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 4rem;
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(10px);
            animation: bounce 2s ease-in-out infinite;
        }

        @keyframes bounce {
            0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
            40% { transform: translateY(-10px); }
            60% { transform: translateY(-5px); }
        }

        /* Content styles */
        .error-title {
            font-size: 2.5rem;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 1rem;
            letter-spacing: -0.02em;
        }

        .error-subtitle {
            font-size: 1.2rem;
            color: var(--text-secondary);
            margin-bottom: 1.5rem;
            font-weight: 500;
        }

        .error-message {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 12px;
            padding: 1.5rem;
            margin: 2rem 0;
            font-family: 'JetBrains Mono', monospace;
            color: var(--text-secondary);
            font-size: 0.95rem;
            line-height: 1.6;
            text-align: left;
            word-break: break-word;
        }

        /* Action buttons */
        .actions {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            margin-top: 2.5rem;
        }

        .action-button {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.75rem;
            padding: 1rem 2rem;
            text-decoration: none;
            border-radius: 12px;
            font-weight: 600;
            font-size: 1rem;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
            background: none;
        }

        .action-primary {
            background: rgba(255, 255, 255, 0.2);
            color: var(--text-primary);
            border: 1px solid rgba(255, 255, 255, 0.3);
        }

        .action-primary:hover {
            background: rgba(255, 255, 255, 0.3);
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg);
        }

        .action-secondary {
            background: transparent;
            color: var(--text-secondary);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .action-secondary:hover {
            background: rgba(255, 255, 255, 0.1);
            color: var(--text-primary);
        }

        .action-danger {
            background: rgba(255, 107, 107, 0.2);
            color: var(--text-primary);
            border: 1px solid rgba(255, 107, 107, 0.3);
        }

        .action-danger:hover {
            background: rgba(255, 107, 107, 0.3);
            transform: translateY(-2px);
        }

        .action-row {
            display: flex;
            gap: 1rem;
        }

        .action-row .action-button {
            flex: 1;
        }

        /* Technical details */
        .technical-details {
            margin-top: 2rem;
            padding-top: 2rem;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
        }

        .details-toggle {
            background: none;
            border: none;
            color: var(--text-secondary);
            cursor: pointer;
            font-size: 0.9rem;
            padding: 0.5rem;
            border-radius: 6px;
            transition: all 0.3s ease;
        }

        .details-toggle:hover {
            background: rgba(255, 255, 255, 0.1);
            color: var(--text-primary);
        }

        .details-content {
            display: none;
            margin-top: 1rem;
            padding: 1rem;
            background: rgba(0, 0, 0, 0.2);
            border-radius: 8px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.8rem;
            color: var(--text-secondary);
            text-align: left;
            white-space: pre-wrap;
            word-break: break-all;
        }

        .details-content.visible {
            display: block;
        }

        /* Responsive design */
        @media (max-width: 600px) {
            .error-container {
                min-width: auto;
                width: 90vw;
                margin: 1rem;
                padding: 2rem 1.5rem;
            }

            .error-title {
                font-size: 2rem;
            }

            .action-row {
                flex-direction: column;
            }
        }

        /* Dark mode improvements */
        @media (prefers-color-scheme: dark) {
            .error-message {
                background: rgba(0, 0, 0, 0.3);
            }
        }
    </style>
</head>
<body>
    <div class="bg-animation">
        <div class="bg-element"></div>
        <div class="bg-element"></div>
        <div class="bg-element"></div>
    </div>

    <div class="error-container">
        <div class="error-icon">
            {{ if eq .Type "error" }}😵{{ else if eq .Type "warning" }}⚠️{{ else }}ℹ️{{ end }}
        </div>

        <h1 class="error-title">{{ .Title }}</h1>
        <p class="error-subtitle">{{ .Subtitle }}</p>

        {{ if .Message }}
        <div class="error-message">{{ .Message }}</div>
        {{ end }}

        <div class="actions">
            {{ if .ShowRetry }}
            <button class="action-button action-primary" onclick="location.reload()">
                <span>🔄</span>
                <span>Try Again</span>
            </button>
            {{ end }}

            <div class="action-row">
                {{ if .ShowHome }}
                <a href="{{ .HomePath }}" class="action-button action-secondary">
                    <span>🏠</span>
                    <span>Go Home</span>
                </a>
                {{ end }}

                {{ if .ShowLogout }}
                <form method="POST" action="{{ .LogoutPath }}" style="display: inline;">
                    <button type="submit" class="action-button action-danger">
                        <span>🚪</span>
                        <span>Logout</span>
                    </button>
                </form>
                {{ end }}
            </div>

            {{ if .ShowContact }}
            <a href="mailto:support@company.com" class="action-button action-secondary">
                <span>📧</span>
                <span>Contact Support</span>
            </a>
            {{ end }}
        </div>

        {{ if .TechnicalDetails }}
        <div class="technical-details">
            <button class="details-toggle" onclick="toggleDetails()">
                <span id="toggle-icon">🔽</span> Show Technical Details
            </button>
            <div id="details-content" class="details-content">{{ .TechnicalDetails }}</div>
        </div>
        {{ end }}
    </div>

    <script>
        function toggleDetails() {
            const content = document.getElementById('details-content');
            const icon = document.getElementById('toggle-icon');
            const toggle = document.querySelector('.details-toggle');
            
            if (content.classList.contains('visible')) {
                content.classList.remove('visible');
                icon.textContent = '🔽';
                toggle.innerHTML = '<span id="toggle-icon">🔽</span> Show Technical Details';
            } else {
                content.classList.add('visible');
                icon.textContent = '🔼';
                toggle.innerHTML = '<span id="toggle-icon">🔼</span> Hide Technical Details';
            }
        }
    </script>
</body>
</html>